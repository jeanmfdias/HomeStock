              "path": ["api", "reports", "expiring"],
              "query": [
                { "key": "days", "value": "7", "description": "1–365, default 7" }
              ]
            },
            "description": "Returns the user's products whose `expirationDate` falls within the next `days` days."
          }
        },
        {
          "name": "Shopping list",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/reports/shopping-list",
              "host": ["{{baseUrl}}"],
              "path": ["api", "reports", "shopping-list"]
            },
            "description": "Returns the user's products where `quantity <= minStock`."
          }
        }
      ]
    }
  ]
